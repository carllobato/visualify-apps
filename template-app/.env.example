# Copy to .env.local — do not commit secrets.

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: share auth cookies across Visualify subdomains (set both)
NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=
NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=

# --- Visualify product identity (optional) ---
# When unset, template-app uses defaults: product key `template-app`, HQ apps `https://hq.visualify.com.au/apps`.
# Set explicitly to match staging/production (must match `visualify_products.key` for entitlements).
NEXT_PUBLIC_VISUALIFY_PRODUCT_KEY=
NEXT_PUBLIC_HQ_APPS_URL=

# Optional: cookie sync after refresh (ms). Default 15.
# SUPABASE_AUTH_COOKIE_SYNC_MS=15

# Optional: proxy auth debug logs
# SUPABASE_AUTH_DEBUG=
