# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# Never expose private variables using NEXT_PUBLIC_*.
# Platform contract: ../docs/environment-variables.md

# --- Required (Supabase — same project as HQ, Website, Template App) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Canonical Visualify origins (full origin, no trailing slash) ---
# Production: https://riskai.visualify.com.au, https://hq.visualify.com.au, https://visualify.com.au
# Used by @visualify/urls, dual-host proxy, and cross-app links.
NEXT_PUBLIC_RISKAI_ORIGIN=
NEXT_PUBLIC_HQ_ORIGIN=
NEXT_PUBLIC_WEBSITE_ORIGIN=

# --- Deprecated (optional; code fallbacks only — prefer canonical origins above) ---
# Do not use https://app.visualify.com.au for new values. Remove after production cutover.
# NEXT_PUBLIC_APP_ORIGIN=
# NEXT_PUBLIC_APP_HOST=
# NEXT_PUBLIC_WEBSITE_HOST=
# NEXT_PUBLIC_RISKAI_APP_ORIGIN=
# NEXT_PUBLIC_RISKAI_DASHBOARD_URL=

# --- Visualify product identity (optional) ---
# Default: product key `riskai`, HQ apps https://hq.visualify.com.au/apps
# When set, must match `visualify_products.key` for entitlements.
NEXT_PUBLIC_VISUALIFY_PRODUCT_KEY=
NEXT_PUBLIC_HQ_APPS_URL=

# --- Shared Supabase auth cookies (opt-in) ---
# Enable only on RiskAI + every authenticated app, with identical values. Same Supabase project required.
# Set NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=1 AND NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN (e.g. .visualify.com.au).
NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=
NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=
# Optional: extra delay (ms) after `getUser()` in proxy; default 15.
# SUPABASE_AUTH_COOKIE_SYNC_MS=15

# --- Private (server only) ---
# Supabase → Project Settings → API → service_role. Never use NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# Required for AI rate limiting (see riskai/docs/R22_AI_RATE_LIMITING.md)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional / feature flags ---
# Leave unset during shared HQ ↔ RiskAI auth (see docs/environment-variables.md §13).
# NEXT_PUBLIC_RISKAI_ENABLE_SINGLE_SESSION_GUARD=1
# App-shell migration test mode only; default off.
# NEXT_PUBLIC_RISKAI_ENABLE_APP_SHELL=1
# AI_RATE_LIMIT_MAX=
# AI_RATE_LIMIT_WINDOW_SEC=
# PORTFOLIO_INVITE_DEBUG=1

# --- Local dev only (never on Vercel; DEV_SKIP_AUTH_GUARD blocked when VERCEL=1) ---
# DEV_SKIP_AUTH_GUARD=1
# SUPABASE_AUTH_DEBUG=1
