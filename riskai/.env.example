# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# Never expose private variables using NEXT_PUBLIC_.

# --- Public (safe for browser) ---
# Required
NEXT_PUBLIC_SUPABASE_URL=
# Required
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required
NEXT_PUBLIC_APP_HOST=
# Required
NEXT_PUBLIC_WEBSITE_HOST=
# Required
NEXT_PUBLIC_APP_ORIGIN=
# Required
NEXT_PUBLIC_WEBSITE_ORIGIN=

# --- Visualify product identity (optional) ---
# When unset, RiskAI uses defaults: product key `riskai`, HQ apps `https://hq.visualify.com.au/apps`.
# Set explicitly to match other apps / staging (must match `visualify_products.key` for entitlements).
NEXT_PUBLIC_VISUALIFY_PRODUCT_KEY=
NEXT_PUBLIC_HQ_APPS_URL=

# --- Shared Supabase auth cookies & proxy (optional) ---
# Cookie sharing across subdomains (e.g. hq.* and app.*) is OPT-IN. When enabled, HQ + every product
# app must use the SAME values and the same Supabase project, or sessions will diverge.
# Production domain format is typically `.visualify.com.au` (leading dot = parent domain scope).
NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=
NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=
# Optional: extra delay (ms) after `getUser()` in proxy so Set-Cookie finishes; default 15.
SUPABASE_AUTH_COOKIE_SYNC_MS=
# Optional: platform-standard name (e.g. template-app proxy); set to 1 where supported for auth debug logs.
SUPABASE_AUTH_DEBUG=

# --- Private (server only) ---
# Required for server-side admin actions: Settings → Delete account, and Project → Send invitation.
# Supabase → Project Settings → API → Project API keys → service_role (secret). Never use NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
# Required
OPENAI_API_KEY=

# --- Optional / Feature flags ---
# Optional: set to 1 to re-enable RiskAI single-session enforcement (visualify_user_sessions JWT match).
# Omit or leave unset for MVP (default): guard is not mounted — avoids logout after HQ login with shared auth cookies.
NEXT_PUBLIC_RISKAI_ENABLE_SINGLE_SESSION_GUARD=

# Optional: app-shell migration (Phase 1D). unset or 0 = legacy RiskAI shell (Sidebar + TopNav).
# Set to 1 only for app-shell migration test mode (@visualify/app-shell rail/frame). Default: off.
NEXT_PUBLIC_RISKAI_ENABLE_APP_SHELL=1

# Optional: max requests allowed in rate-limit window
AI_RATE_LIMIT_MAX=
# Optional: rate-limit window in seconds
AI_RATE_LIMIT_WINDOW_SEC=
# Optional: set to 1 to enable portfolio invite debug behavior
PORTFOLIO_INVITE_DEBUG=

# Optional local dev flag used by auth bypass helper
DEV_SKIP_AUTH_GUARD=

# Runtime/platform-provided (usually do not set manually in .env.local)
# NODE_ENV=
# VERCEL=
# NETLIFY=
