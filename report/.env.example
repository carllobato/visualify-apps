# Copy to `.env.local` — do not commit secrets.
# Platform contract: ../docs/environment-variables.md

# --- Required (Supabase — same project as HQ, RiskAI, Website) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Canonical Visualify origins (full origin, no trailing slash) ---
# Production: https://report.visualify.com.au, https://hq.visualify.com.au, https://visualify.com.au
NEXT_PUBLIC_REPORT_ORIGIN=
NEXT_PUBLIC_HQ_ORIGIN=
NEXT_PUBLIC_RISKAI_ORIGIN=
NEXT_PUBLIC_WEBSITE_ORIGIN=

# --- Visualify product identity (optional) ---
# Default: `report`, HQ apps https://hq.visualify.com.au/apps
# When set, must match `visualify_products.key` for entitlements.
NEXT_PUBLIC_VISUALIFY_PRODUCT_KEY=
NEXT_PUBLIC_HQ_APPS_URL=

# --- Shared Supabase auth cookies (opt-in) ---
# Enable only on Report + every authenticated app, with identical values.
# Set NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=1 AND NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN (e.g. .visualify.com.au).
NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=
NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=

# --- Server-only (project metadata updates) ---
# SUPABASE_SERVICE_ROLE_KEY=

# --- Optional ---
# SUPABASE_AUTH_COOKIE_SYNC_MS=15
# SUPABASE_AUTH_DEBUG=1
