# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# Platform contract: ../docs/environment-variables.md

# --- Required (Supabase — same project as RiskAI, Website, Template App) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: workspace invites, invitations API, account deletion. Never use NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# --- Canonical Visualify origins (full origin, no trailing slash) ---
# Production: https://hq.visualify.com.au, https://riskai.visualify.com.au, https://visualify.com.au
NEXT_PUBLIC_HQ_ORIGIN=
NEXT_PUBLIC_RISKAI_ORIGIN=
NEXT_PUBLIC_WEBSITE_ORIGIN=

# --- Optional: HQ apps launcher override ---
# Default: `{NEXT_PUBLIC_HQ_ORIGIN}/apps` or https://hq.visualify.com.au/apps
NEXT_PUBLIC_HQ_APPS_URL=

# --- Shared Supabase auth cookies (opt-in) ---
# Enable only on HQ + every authenticated app, with identical values. Same Supabase project required.
# Set NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=1 AND NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN (e.g. .visualify.com.au).
NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=
NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=

# --- Optional: local dev / staging only (never on Vercel Production or Preview) ---
# NEXT_PUBLIC_HQ_AUTH_DISABLED=true
# HQ_SUPABASE_AUTH_DEBUG=1
# HQ_SUPABASE_AUTH_SYNC_MS=15
