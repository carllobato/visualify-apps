# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# --- Required (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: workspace invite acceptance, invitations API, account deletion. Never use NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# --- Canonical Visualify origins (platform standard) ---
# Production examples: https://hq.visualify.com.au, https://app.visualify.com.au
# HQ launcher tiles and RiskAI links use @visualify/urls when unset (see package defaults).
NEXT_PUBLIC_HQ_ORIGIN=
NEXT_PUBLIC_RISKAI_ORIGIN=
NEXT_PUBLIC_WEBSITE_ORIGIN=

# --- Optional: HQ apps launcher override ---
# Default: `{NEXT_PUBLIC_HQ_ORIGIN}/apps` or https://hq.visualify.com.au/apps
NEXT_PUBLIC_HQ_APPS_URL=

# --- Shared Supabase auth cookies (opt-in) ---
# Set both when sharing sessions across hq.* and app.* (same Supabase project required).
NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=
NEXT_PUBLIC_HQ_SHARE_AUTH_COOKIE_DOMAIN=

# --- Optional: local dev only ---
# NEXT_PUBLIC_HQ_AUTH_DISABLED=true
# HQ_SUPABASE_AUTH_DEBUG=1
# HQ_SUPABASE_AUTH_SYNC_MS=15
